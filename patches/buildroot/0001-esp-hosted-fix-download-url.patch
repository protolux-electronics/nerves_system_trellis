From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: nerves_system_trellis <nerves@trellis>
Date: Sat, 29 Mar 2026 00:00:00 +0000
Subject: [PATCH] esp-hosted: fix download URL for release tags with slashes

The github helper appends the version as a path segment, then the
download logic appends /<SOURCE>.  When the tag contains a slash
(release/ng-v1.0.4.0.0), the resulting URL gains an extra path
component that GitHub does not serve:

  .../archive/release/ng-v1.0.4.0.0/ng-v1.0.4.0.0.tar.gz  (broken)

Set ESP_HOSTED_SITE directly so the URL resolves correctly:

  .../archive/release/ng-v1.0.4.0.0.tar.gz  (correct)

---
 package/esp-hosted/esp-hosted.mk | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/package/esp-hosted/esp-hosted.mk b/package/esp-hosted/esp-hosted.mk
index 1234567..abcdefg 100644
--- a/package/esp-hosted/esp-hosted.mk
+++ b/package/esp-hosted/esp-hosted.mk
@@ -5,7 +5,7 @@
 ################################################################################

 ESP_HOSTED_VERSION = 1.0.4.0.0
-ESP_HOSTED_SITE = $(call github,espressif,esp-hosted,release/ng-v$(ESP_HOSTED_VERSION))
+ESP_HOSTED_SITE = https://github.com/espressif/esp-hosted/archive/release
 ESP_HOSTED_SOURCE = ng-v$(ESP_HOSTED_VERSION).tar.gz
 ESP_HOSTED_DEPENDENCIES = linux
 ESP_HOSTED_LICENSE = GPL-2.0
